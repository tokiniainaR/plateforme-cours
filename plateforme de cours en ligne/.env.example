# Plateforme de Cours en Ligne - Configuration d'environnement

# URL de l'API Backend
# Exemple local: http://localhost:5000/api
# Exemple production: https://api.plateforme-cours.com/api
REACT_APP_API_URL=http://localhost:5000/api

# Mode environnement
# Valeurs possibles: development, production, test
REACT_APP_ENV=development

# Timeout des requêtes API (en millisecondes)
REACT_APP_API_TIMEOUT=30000

# Authentification
# Clé pour le stockage du token JWT
REACT_APP_TOKEN_KEY=authToken

# Logging (pour développement)
# Valeurs possibles: true, false
REACT_APP_DEBUG=true

# Profondeur de pagination (par défaut)
REACT_APP_PAGE_SIZE=10

# URL du serveur de développement Vite
# (généralement pas nécessaire dans .env)
# VITE_PORT=5173
